"use client";
import React, { useState } from 'react';
import { ChevronLeft, Check, Plus, Target, Flame } from 'lucide-react';

export default function HabitsPage() {
  const [habits, setHabits] = useState([
    { id: 1, name: "Treino na Academia", done: true, streak: 5 },
    { id: 2, name: "Leitura Técnica", done: false, streak: 12 },
    { id: 3, name: "Organizar Finanças", done: false, streak: 3 },
    { id: 4, name: "Beber 3L de Água", done: true, streak: 20 },
  ]);

  const toggleHabit = (id: number) => {
    setHabits(habits.map(h => h.id === id ? { ...h, done: !h.done } : h));
  };

  return (
    <div className="min-h-screen bg-[#09090b] text-white p-4 pb-24 font-sans">
      {/* Header com Voltar */}
      <header className="flex items-center gap-4 py-6">
        <button onClick={() => window.location.href='/'} className="p-2 bg-zinc-900 rounded-lg border border-zinc-800">
          <ChevronLeft size={20} />
        </button>
        <h1 className="text-xl font-bold font-sans">Meus Hábitos</h1>
      </header>

      {/* Resumo de Hoje */}
      <div className="bg-gradient-to-r from-purple-900/40 to-zinc-900 border border-purple-500/20 rounded-2xl p-5 mb-8">
        <div className="flex justify-between items-center mb-4">
          <div className="flex items-center gap-2">
            <Target className="text-purple-400" size={24} />
            <span className="text-sm font-bold uppercase tracking-widest text-purple-400">Foco Diário</span>
          </div>
          <span className="text-xs bg-purple-500/20 px-2 py-1 rounded text-purple-300 font-bold">50% CONCLUÍDO</span>
        </div>
        <p className="text-sm text-zinc-300 italic">"Rogério, completar a leitura técnica hoje te dará um bônus de 50 XP!"</p>
      </div>

      {/* Lista de Hábitos */}
      <div className="space-y-4">
        {habits.map((habit) => (
          <div 
            key={habit.id} 
            onClick={() => toggleHabit(habit.id)}
            className={`flex items-center justify-between p-4 rounded-2xl border transition-all ${
              habit.done ? 'bg-zinc-900/50 border-green-500/30 opacity-70' : 'bg-zinc-900 border-zinc-800'
            }`}
          >
            <div className="flex items-center gap-4">
              <div className={`w-6 h-6 rounded-full border-2 flex items-center justify-center ${
                habit.done ? 'bg-green-500 border-green-500' : 'border-zinc-700'
              }`}>
                {habit.done && <Check size={14} className="text-black font-bold" />}
              </div>
              <div>
                <h3 className={`font-bold ${habit.done ? 'line-through text-zinc-500' : 'text-zinc-200'}`}>
                  {habit.name}
                </h3>
                <div className="flex items-center gap-1 mt-1">
                  <Flame size={12} className="text-orange-500" />
                  <span className="text-[10px] text-zinc-500 font-bold">{habit.streak} DIAS SEGUIDOS</span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      {/* Botão Flutuante Adicionar */}
      <button className="fixed bottom-28 right-6 w-14 h-14 bg-blue-600 rounded-full flex items-center justify-center shadow-lg shadow-blue-500/20 active:scale-90 transition-transform">
        <Plus size={28} />
      </button>

      {/* Navegação fixa você já tem na Home, podemos depois transformar em um componente para aparecer em todas. */}
    </div>
  );
}
